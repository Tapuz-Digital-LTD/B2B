# Server-side env vars for /api/catalog (set these in Vercel → Project → Environment Variables).
# Locally they are read by `vercel dev`; plain `npm run dev` (vite) has no /api and shows the error state.

# The production store domain
SHOPIFY_STORE_DOMAIN=xtra-gift-card.myshopify.com

# Token of a dedicated Shopify custom app with the read_products scope ONLY.
# Do NOT reuse the XtraGiftCard-NestApp admin token.
SHOPIFY_ADMIN_TOKEN=shpat_xxx

# Handle of the Catalog Collection (see CONTEXT.md — "קולקציית הקטלוג")
CATALOG_COLLECTION_HANDLE=website-catalog
